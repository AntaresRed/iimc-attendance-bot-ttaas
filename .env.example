# ─── Bot Identity ──────────────────────────────────────────────────────────────
# Phone number of the first CR (bootstrap admin). Format: country code + number
# Example: 919876543210  (no + or spaces)
BOOTSTRAP_CR_PHONE=91XXXXXXXXXX

# ─── Class Configuration ───────────────────────────────────────────────────────
# Your institution / batch name
CLASS_NAME=IIMC

# Number of sections (default 6)
TOTAL_SECTIONS=6

# Minutes before/after class start time to allow attendance marking
ATTENDANCE_WINDOW_MINUTES=15

# ─── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file (relative to project root)
DB_PATH=./data/attendance.db

# ─── Sessions ──────────────────────────────────────────────────────────────────
# Directory where Baileys session files are stored
SESSION_DIR=./sessions

# ─── Uploads ───────────────────────────────────────────────────────────────────
# Directory where timetable PNG uploads are temporarily stored
UPLOADS_DIR=./uploads

# ─── Logging ───────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
